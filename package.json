{
  "name": "signaltrail",
  "version": "0.1.0",
  "description": "Minimal secure Electron recorder for screenshots, mouse telemetry, and JSONL session storage.",
  "main": "src/main/main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "electron .",
    "smoke": "node scripts/smoke.mjs",
    "package:mac": "npx @electron/packager . SignalTrail --platform=darwin --arch=arm64,x64 --icon=src/renderer/assets/signaltrail-logo.icns --out=dist --overwrite"
  },
  "keywords": [
    "electron",
    "recorder",
    "computer-use",
    "jsonl"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "electron": "^42.1.0"
  }
}
